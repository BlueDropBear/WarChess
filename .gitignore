# ================================
# Unity .gitignore
# ================================

# Library & temp folders (Unity regenerates these)
**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/

# Memory & crash reports
**/[Mm]emoryCaptures/
**/[Rr]ecordings/

# Asset meta files generated by the editor
*.pidb
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb.meta
*.pdb
*.pdb.meta
*.mdb
*.mdb.meta

# VS / Rider IDE files
.vs/
.idea/
*.csproj
*.sln

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Builds output
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Addressables (if used later)
**/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
**/[Ss]treamingAssets/aa.meta
**/[Ss]treamingAssets/aa/*
